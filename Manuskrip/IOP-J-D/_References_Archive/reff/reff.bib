@article{wang_simulation_2024,
	title = {Simulation of laser-induced plasma temperature based on machine learning},
	abstract = {Laser-induced breakdown spectroscopy (LIBS), a rapid and nondestructive elemental analysis method, is widely applied across various fields. This technique is used for elemental analysis of materials by analyzing the light emitted from laser-induced plasma, with plasma temperature being a crucial parameter. This study focused on obtaining time-resolved spectra of Cu samples at different distances from the lens to the sample using LIBS in conjunction with the following machine-learning algorithms to simulate plasma temperature: decision trees, support vector machine, Gaussian process regression, and neural network. The study compared the accuracy of these four algorithms before and after normalization based on the Cu (I) spectral line at 510.55 nm. All four algorithms achieved a correlation coefficient greater than 0.95 after normalization. The Gaussian process regression model provided excellent predictions before and after normalization with a correlation coefficient of 0.99, demonstrating the advantages of this model in plasma temperature simulation. This study confirmed that machine learning can effectively, conveniently, and accurately predict laser-induced plasma temperature, providing significant utility in LIBS research.},
	language = {en},
	author = {Wang, Ying and Gao, Heyan and Ye, Jifei and Chen, Anmin and Wang, Diankai and Li, Sai and Cui, Qianqian},
	year = {2024},
	file = {PDF:files/486/Wang et al. - 2024 - Simulation of laser-induced plasma temperature based on machine learning.pdf:application/pdf},
}

@article{gao_machine_2025,
	title = {Machine learning-based prediction of laser ablation impulse from plasma spectra},
	volume = {32},
	issn = {1070-664X, 1089-7674},
	url = {https://pubs.aip.org/pop/article/32/6/063301/3349024/Machine-learning-based-prediction-of-laser},
	doi = {10.1063/5.0257411},
	abstract = {This study explores a machine learning-based approach for predicting the micro-thrust generated by laser ablation of aluminum alloy materials using laser-induced breakdown spectroscopy (LIBS). An impulse-spectroscopy coupled measurement technique is introduced to construct datasets combining plasma spectral information and impulse coupling coefficients under various laser parameters. Using these datasets, support vector machine, and Neural Network models are developed to establish relationships between plasma spectral parameters and the propulsion performance of high-energy pulsed laser ablation. The models demonstrate the ability to predict impulse coupling coefficients based on plasma spectral data, achieving an R2 value of up to 0.998 for aluminum alloy targets under specific conditions. These findings highlight the potential of LIBS-based methods for measuring laser propulsion performance and provide data-driven insights for understanding the interactions between laser ablation and material properties.},
	language = {en},
	number = {6},
	urldate = {2026-03-23},
	journal = {Physics of Plasmas},
	author = {Gao, Heyan and Wang, Ying and Ye, Jifei and Chen, Anmin and Wen, Ming and Wang, Diankai and Du, Bangdeng and Li, Sai and Cui, Qianqian},
	month = jun,
	year = {2025},
	pages = {063301},
	file = {Full Text PDF:files/490/Gao et al. - 2025 - Machine learning-based prediction of laser ablation impulse from plasma spectra.pdf:application/pdf;PDF:files/489/Gao et al. - 2025 - Machine learning-based prediction of laser ablation impulse from plasma spectra.pdf:application/pdf},
}

@article{zaytsev_accurate_2026,
	title = {Accurate simulation of the {CN} emission spectra in laser-induced plasma: a joint impact of robust line list, non-{LTE} conditions and self-absorption effect},
	volume = {235},
	issn = {05848547},
	shorttitle = {Accurate simulation of the {CN} emission spectra in laser-induced plasma},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0584854725002356},
	doi = {10.1016/j.sab.2025.107350},
	abstract = {A non-local thermodynamic equilibrium (non-LTE) radiative transfer algorithm, accounting for self-absorption effect explicitly, was implemented for the simulation of high-temperature (T{\textasciitilde}4500-6600 K) moderate resolution (Δλ {\textasciitilde} 0.04 nm) spectra of the diagonal (Δυ=0) bands of B 2Σ+ – X 2Σ+ (violet) system of the CN radical. The experimental spectra were obtained in laser-induced plasma during the ablation of nitrogen containing carbonaceous solid target in air and emission registration at 12 different delays (0.2-6 μs) after nanosecond laser pulse. A performance comparison of the two publicly available line lists containing spectroscopic data on CN transitions in ExoMol format, namely, Trihybrid and KTPSYT, showed the advantage of the last one for experimental data fitting. Using the KTPSYT line list, a step-by-step expansion of the model was carried out, starting with the singletemperature (T) LTE and optically thin plasma and finishing with the multi-temperature (Tel = T (obtained under LTE condition), Tvib, Trot) non-LTE optically thick plasma approximations. The multi-temperature Boltzmann distribution of internal kinds of molecular motion was assumed during the non-LTE modeling. The LTE model with self-absorption was applicable for the data explanation obtained at early delays after laser pulse. Both of non-LTE and self-absorption effects appeared at the middle delays and its simultaneous consideration substantially improved the overall fit of the experimental data (the relative squared deviation of the normalized intensity decreased twice down to {\textasciitilde}7 \% in comparison with implementation of the simple LTE model without selfabsorption). At the late delays the plasma density decreases and the degree of absorption becomes low, whereas the strong difference up to 1800 K is observed between Tvib and Trot values. The significance of the adjusted plasma parameters was elucidated by routinely errors assessment.},
	language = {en},
	urldate = {2026-03-25},
	journal = {Spectrochimica Acta Part B: Atomic Spectroscopy},
	author = {Zaytsev, Sergey M. and Terashkevich, Vera A.},
	month = jan,
	year = {2026},
	pages = {107350},
	file = {PDF:files/499/Zaytsev and Terashkevich - 2026 - Accurate simulation of the CN emission spectra in laser-induced plasma a joint impact of robust lin.pdf:application/pdf},
}

@article{wu_novel_2025,
	title = {A novel multi-constraint {SVR} surrogate model: {Interactive} reliability-based design optimization and case study},
	volume = {79},
	issn = {2352-0124},
	shorttitle = {A novel multi-constraint {SVR} surrogate model},
	url = {https://www.sciencedirect.com/science/article/pii/S2352012425012688},
	doi = {10.1016/j.istruc.2025.109453},
	abstract = {Reliability-based design optimization (RBDO) is widely applied to address uncertainty in structural design. However, the traditional surrogate model approaches train independent models for each probabilistic constraint, thus neglecting underlying (potentially nonlinear) interactions among these constraints. This study incorporates a multi-task learning mechanism into the safe region during the training phase of the support vector regression (SVR) surrogate model. Thus, an effective multi-constraint SVR surrogate model is produced. The multi-constraint SVR surrogate model serves as an effective surrogate for multiple probabilistic constraint functions and integrates a multi-task learning mechanism to capture interactions among these constraints. In the RBDO framework, the objective function and multi-constraint formulations are systematically established through the proposed multi-constraint SVR surrogate model, with the pelican optimization algorithm subsequently executing the solution search process. This biologically-inspired algorithm, derived from observations of pelicans' coordinated foraging behaviors, demonstrates superior effectiveness in overcoming RBDO's inherent computational challenges. This proposed RBDO framework is validated through four case studies involving complex probabilistic constraints. Results indicate significant improvement in computational efficiency while maintaining high accuracy. Moreover, iterative convergence curves and design parameter collections from case studies support the development of high-reliability, high-performance RBDO strategies.},
	urldate = {2026-03-27},
	journal = {Structures},
	author = {Wu, Jiawei and Wan, Siyu and Yang, Yujun and Liu, Zhirou and Han, Yunxia and Zhang, Hanyu and Huang, Zhicheng},
	month = sep,
	year = {2025},
	keywords = {Multi-constraint support vector regression, Multiple probabilistic constraints, Reliability-based design optimization, Structural reliability},
	pages = {109453},
	file = {ScienceDirect Snapshot:files/517/S2352012425012688.html:text/html},
}

