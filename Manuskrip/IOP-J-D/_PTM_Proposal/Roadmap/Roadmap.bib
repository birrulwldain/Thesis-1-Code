@article{pardede_high_2021,
	title = {High sensitivity hydrogen analysis in zircaloy-4 using helium-assisted excitation laser-induced breakdown spectroscopy},
	volume = {11},
	issn = {2045-2322},
	url = {https://www.nature.com/articles/s41598-021-01601-y},
	doi = {10.1038/s41598-021-01601-y},
	abstract = {Abstract
            High-sensitivity detection of hydrogen (H) contained in zircaloy-4, a commonly used material for nuclear fuel containers, is crucial in a nuclear power plant. Currently, H detection is performed via gas chromatography, which is an offline and destructive method. In this study, we developed a technique based on metastable excited-state He-assisted excitation to achieve excellent quality of H emission spectra in double-pulse orthogonal laser-induced breakdown spectroscopy (LIBS). The production of metastable excited-state He atoms is optimized by using LiF as sub-target material. The results show a narrow full-width-at-half-maximum of 0.5 Å for the H I 656.2 nm emission line, with a detection limit as low as 0.51 mg/kg. Thus, using this novel online method, H in zircaloy-4 can be detected efficiently, even at very low concentrations.},
	language = {en},
	number = {1},
	urldate = {2026-04-18},
	journal = {Scientific Reports},
	author = {Pardede, Marincan and Karnadi, Indra and Hedwig, Rinda and Tanra, Ivan and Iqbal, Javed and Marpaung, Mangasi Alion and Suliyanti, Maria Margaretha and Jobiliong, Eric and Abdulmadjid, Syahrun Nur and Idris, Nasrullah and Khumaeni, Ali and Shiddiq, Muhandis and Rhizma, Mario Gracio Anduinta and Lie, Zener Sukra and Bilal, Muhammad and Kurniawan, Davy Putra and Lie, Tjung Jie and Kurniawan, Koo Hendrik and Kagawa, Kiichiro},
	month = nov,
	year = {2021},
	pages = {21999},
	file = {Full Text:/Users/birrulwldain/Zotero/storage/7CBWAN7J/Pardede et al. - 2021 - High sensitivity hydrogen analysis in zircaloy-4 using helium-assisted excitation laser-induced brea.pdf:application/pdf},
