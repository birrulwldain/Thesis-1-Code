@article{sari_assessing_2020,
	title = {Assessing the temperature of plasma produced in carbon dioxide ({CO}$_{\textrm{2}}$ ) {Laser}-{Induced} {Breakdown} {Spectroscopy} ({LIBS}) from soil sample prepared by two different methods of metal mesh and silicone grease},
	volume = {1572},
	issn = {1742-6588, 1742-6596},
	url = {https://iopscience.iop.org/article/10.1088/1742-6596/1572/1/012010},
	doi = {10.1088/1742-6596/1572/1/012010},
	abstract = {Abstract
            
              Temperature of plasma generated by CO
              2
              laser from soil sample prepared by the two different methods, namely metal mesh, and silicone grease methods, was examined. The plasma was produced by focusing the laser beam on the sample at 1 atmospheric pressure. The plasma characteristics namely temperature was estimated by the Boltzmann plot method. The detection was made in region of 300 nm-400 nm. In the case sample prepared using the metal mesh method, the estimated temperature was about 11605 K for the metal mesh no. 50 and 12440 K for mesh no. 40, respectively when helium was used as surrounding gas. When air was used as surrounding gas, plasma temperature was about 10315 K and 10990 K, respectively. In case the soil sample prepared by soil mixed with silicon grease (SMS) smeared on a surface of metal sub target, plasma temperature was about 8913 K and 9218 K for air and helium as a surrounding gas, respectively. It can be concluded that plasma temperature is not significantly different although the sample was prepared with different methods.},
	number = {1},
	urldate = {2026-04-18},
	journal = {Journal of Physics: Conference Series},
	author = {Sari, A M and Lahna, K and Idris, N and Ramli, M and Kurihara, K and {Marwan}},
	month = jun,
	year = {2020},
	pages = {012010},
	file = {Full Text:/Users/birrulwldain/Zotero/storage/XNCRUGHN/Sari et al. - 2020 - Assessing the temperature of plasma produced in carbon dioxide (CO2 ) Laser-Induced Break.pdf:application/pdf},
}

@article{idris_elemental_2020,
	title = {Elemental analysis of agriculture soil by a pulsed carbon dioxide ({CO}$_{\textrm{2}}$ ) {Laser} {Induced} {Breakdown} {Spectroscopy} ({LIBS})},
