@article{subki_analysis_2025,
	title = {Analysis of organic egg authenticity determination using laser-induced breakdown spectroscopy ({LIBS}) assisted by artificial neural networks ({ANN})},
	volume = {1510},
	issn = {1755-1307, 1755-1315},
	url = {https://iopscience.iop.org/article/10.1088/1755-1315/1510/1/012088},
	doi = {10.1088/1755-1315/1510/1/012088},
	abstract = {Abstract
            The increasing demand for organic chicken eggs has led to cases of counterfeit organic eggs being sold, often produced using commercially-fed chickens. A reliable and accurate method is therefore required to verify the authenticity of organic eggs. This study aims to determine the authenticity of organic eggs by analyzing emission spectra from eggshells using Laser Induced Breakdown Spectroscopy (LIBS) combined with Artificial Neural Networks (ANN). LIBS was chosen for its modern analytical capability with minimal sample preparation, while ANN provides robust classification support. The samples consisted of organic and non-organic eggshells, collected from five groups with controlled feeding: one entirely organic-fed group (100\% organic), a completely non-organic group (0\% organic), and three other groups with combined feed. A neodymium-doped yttrium aluminum garnet (Nd-YAG) laser was applied to the samples at 1 ATM pressure, producing plasma in an atmospheric air environment. Emission spectra from the plasma were captured by an Optical Multichannel Analyzer (OMA) for elemental analysis. The ANN model was then built to classify the samples based on the spectral data, successfully demonstrating a good classification ability in distinguishing between sample groups. The elemental composition of eggshell samples included Ca, C, O, P, S, Mg, V, Pb, Cr, Hg, Na, Zn, Cu, N, K, and Sr, with Ca showing the highest intensity due to its abundance. These findings demonstrate the potential of LIBS integrated with ANN for organic egg authenticity verification and suggest its applicability in detecting compositional variations at different authenticity levels.},
	number = {1},
	urldate = {2026-04-18},
	journal = {IOP Conference Series: Earth and Environmental Science},
	author = {Subki, K and Putri, A and Qusthalani, A and Sari, N H P and Subianto, M and {Rajibussalim} and Sadami, K and Ramli, M and Lahna, K and Idris, N},
	month = jun,
	year = {2025},
	pages = {012088},
	file = {IOP Full Text PDF:/Users/birrulwldain/Zotero/storage/9GN9VZSJ/Subki et al. - 2025 - Analysis of organic egg authenticity determination using laser-induced breakdown spectroscopy (LIBS).pdf:application/pdf},
}

@inproceedings{walidain_spectroscopic_2025,
	address = {Surakarta, Indonesia},
	title = {Spectroscopic {Analysis} with a {Case} {Study} in {Traditional} {Women}’s},
	abstract = {Multi-element plasma emission in Laser-Induced Breakdown Spectroscopy (LIBS) is complicated by severe spectral congestion and sensitivity to fluctuating plasma conditions. This work presents a physics-informed computational framework for generating realistic synthetic LIBS corpora by simulating plasma in local thermodynamic equilibrium (LTE). The framework generates 50,000 synthetic spectra for 17 elements across temperatures from 5,000 K to 15,000 K and electron densities (Ne) from 1 × 1016 𝑐𝑚−3 to 1 × 1018 𝑐𝑚−3. To quantify the fundamental limits of spectral observability, we introduce three resolution-aware diagnostics grounded in classical signal and ecological theory: the Symmetric Overlap Index ( 𝑆𝐴𝐵 ), the Resolution-Dependent Coverage Function 𝐶(𝛿), and the Spectral Blending Integral (OIS). These diagnostics reveal a non-linear escalation of interference, identifying transition metals as a "spectral veil" that triggers informational collapse in complex inventories. The utility of this audited dataset is demonstrated via a case study on traditional medicine from Banda Aceh. A model trained solely on these synthetic spectra successfully differentiates organic elements, minerals, and trace metals in a real-world matrix, in agreement with independently diagnosed Calibration Free-LIBS (CF-LIBS) lines. The study illustrates that a physics-grounded, matrix-agnostic training strategy can effectively support qualitative multi-element screening when matrix-matched reference materials are scarce.},
	language = {en},
	booktitle = {Proceedings of the 9th {International} {Conference} on {Science} and {Applied} {Science} ({ICSAS} 2025)},
	author = {Walidain, Birrul and Idris, Nasrullah and Saddami, Khairun and Yuzza, Natasya and Mitaphonna, Rara},
	year = {2025},
	note = {Status: Under review (major revision)
Conference: ICSAS 2025 / ICTAP 2025
Manuscript submitted to conference proceedings},
	file = {PDF:/Users/birrulwldain/Zotero/storage/AH8PXPLA/Walidain et al. - Spectroscopic Analysis with a Case Study in Traditional Women’s.pdf:application/pdf},
}

@article{idris_characteristics_2004,
