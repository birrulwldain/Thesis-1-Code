@article{aliandri_evaluation_2025,
	title = {Evaluation of fourier transform infrared spectroscopy ({FTIR}) spectra obtained from volcanic soil of {Mount} {Seulawah} {Agam} taken in {Seulimum} {Subdistrict} in {Aceh} {Besar} {Regency}, {Aceh}, {Indonesia}},
	volume = {1510},
	issn = {1755-1307, 1755-1315},
	url = {https://iopscience.iop.org/article/10.1088/1755-1315/1510/1/012090},
	doi = {10.1088/1755-1315/1510/1/012090},
	abstract = {Abstract
            Mount Seulawah Agam was formed by the northward movement of the Indo-Australian plate colliding with the Eurasian plate. The identification of volcanic deposits produced by the volcanic activity of Seulawah Agam is important to understand the eruption characteristics and potential geological hazards. This study uses the Fourier Transform Infrared Spectroscopy (FTIR) method to analyze the mineral content in volcanic deposits. The volcanic sediment sampling technique was carried out in the Lambada area, Seulimum with different depths, namely 20 cm, 40 cm, and 60 cm. FTIR analysis utilized the infrared spectra of the minerals in the samples, which were compared with standard spectral data to determine the mineral type. The results showed that volcanic deposits at Mount Seulawah Agam consisted mostly of Si-O, H-O-H, C-O, and Fe-O compounds. These compounds indicate the presence of silicate minerals such as quartz and feldspar, as well as the presence of iron oxides and some carbonates. The presence of these minerals provides information about magmatic processes and environmental conditions during eruptions. This research makes an important contribution to the field of volcanology, especially in the development of geochemical and mineralogical analysis methods that can deepen understanding of volcanic activity and implications for natural disaster mitigation.},
	number = {1},
	urldate = {2026-04-18},
	journal = {IOP Conference Series: Earth and Environmental Science},
	author = {Aliandri, R and Ismail, N and Adillah, N and Khumaeni, A and Indriana, R D and Fiantis, D and Ginting, F I and Idris, N},
	month = jun,
	year = {2025},
	pages = {012090},
	file = {IOP Full Text PDF:/Users/birrulwldain/Zotero/storage/K6QUVJ2Q/Aliandri et al. - 2025 - Evaluation of fourier transform infrared spectroscopy (FTIR) spectra obtained from volcanic soil of.pdf:application/pdf},
